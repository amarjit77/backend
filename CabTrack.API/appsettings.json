{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=cabtrack.db"
  },
  "JwtSettings": {
    "Secret": "SuperSecretKeyDontShare123!",
    "ExpiresInMinutes": 120,
    "Issuer": "CabTrackApi",
    "Audience": "CabTrackApiUsers"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
